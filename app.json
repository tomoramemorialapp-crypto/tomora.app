{
  "expo": {
    "name": "Tomora",
    "slug": "tomora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-light.png",
    "scheme": "tomora",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": {
        "light": "./assets/images/icon-light.png",
        "dark": "./assets/images/icon-dark.png"
      },
      "userInterfaceStyle": "automatic"
    },
    "android": {
      "icon": "./assets/images/icon-light.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-light.png",
        "backgroundColor": "#F7EFE6"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "Tomora",
      "shortName": "Tomora",
      "description": "Your family tree, memories, and moments together.",
      "display": "standalone",
      "backgroundColor": "#F7EFE6",
      "themeColor": "#B8872F",
      "lang": "en"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Tomora uses your camera to scan invite QR codes at family meetups.",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7EFE6",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#101112"
          },
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
