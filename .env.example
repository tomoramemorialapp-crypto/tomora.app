# Tomora — Supabase configuration
# These are EXPO_PUBLIC_ vars, so they are embedded in the client bundle.
# Use the PUBLISHABLE key (sb_publishable_...), never the service_role/secret key.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Public app URL for invite, claim, profile, OAuth, and email-verification redirects.
# Web sign-up uses window.location.origin when available; native uses this value.
# Supabase Auth → URL configuration:
#   Site URL: https://tomora.app (or your Vercel preview URL)
#   Redirect URLs: https://tomora.app/auth/callback, http://localhost:8081/auth/callback
#   (same URL for sign-up confirmation, OAuth, and password reset)
EXPO_PUBLIC_APP_URL=https://tomora.app
